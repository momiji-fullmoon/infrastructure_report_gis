{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tameike-api-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "containers": [
    { "class_name": "ApiContainer", "image": "../../../apps/api/Dockerfile.cloudflare", "max_instances": 1 }
  ],
  "durable_objects": { "bindings": [{ "name": "API_CONTAINER", "class_name": "ApiContainer" }] },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["ApiContainer"] }],
  "vars": { "CORS_ALLOWED_ORIGINS": "http://localhost:3000", "ALLOW_MUTATIONS": "false" },
  "env": {
    "production": {
      "name": "tameike-api",
      "vars": { "ALLOW_MUTATIONS": "false" }
    }
  }
}
